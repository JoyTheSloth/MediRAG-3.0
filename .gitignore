dist/
.dist/
.pytest_cache/
.env
*.log
.DS_Store
.idea/
.vs/
.vscode/

# Docker
docker-compose.override.yml

# Ignore .git from subdirectories so we can treat them as part of one repo
Frontend/.git/
Backend/.git/

# Ignore large datasets and indexes for Github
datafinal/
Backend/data/
*.index
*.pkl
*.csv
