# Normalize all text files to LF on commit (prevents CRLF corruption on Windows)
* text=auto
# Explicit LF for all source and config files
*.py   text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.ini  text eol=lf
# CSV must be LF — Windows checkout with CRLF would corrupt rxnorm_cache.csv,
# causing pandas read_csv to include \r in drug names and breaking exact matching.
*.csv  text eol=lf
# Binary files — no text diff or line-ending conversion
data/index/faiss.index        binary
data/index/metadata_store.pkl binary
demo/demo_fallback.json       text eol=lf
data/index/* filter=lfs diff=lfs merge=lfs -text
